{{ template "base" . }}

{{ define "title" }}Admin - Events{{ end }}
{{ define "content" }}
  <div>
    <!-- Header with Add New Event button -->
    <div class="mb-6 flex flex-wrap items-center justify-between gap-4">
      <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Event Administration</h1>
      <a href="/admin/events/new" class="inline-flex items-center rounded-lg bg-{{ .Scheme.Primary }} px-4 py-2 text-sm font-medium text-white hover:bg-{{ .Scheme.PrimaryHover }} focus:outline-none focus:ring-2 focus:ring-{{ .Scheme.Primary }} focus:ring-offset-2 dark:focus:ring-offset-gray-800">
        <span class="material-symbols-outlined mr-2 text-sm">add</span>
        Add New Event
      </a>
    </div>

    <!-- Stats -->
    <div class="mb-6 flex flex-wrap gap-4">
      {{ range $key, $value := .Stats }}
        <div class="w-40 rounded-lg border border-gray-200 bg-white shadow md:w-48 dark:border-gray-700 dark:bg-gray-800">
          <div class="p-6">
            <h5 class="mb-3 truncate text-lg font-semibold text-gray-900 dark:text-white" title="{{ $key }}">
              {{ $key }}
            </h5>
            <div class="flex items-center gap-4">
              <div class="flex">
                <span class="{{ $.Scheme.SymbolPrimary }}">
                  {{ $value.Icon }}
                </span>
              </div>
              <div class="flex">
                <p class="text-xl font-bold text-gray-900 dark:text-white">
                  {{ $value.Value }}
                </p>
              </div>
            </div>
          </div>
        </div>
      {{ end }}
    </div>

    <hr class="mb-6 border-gray-200 dark:border-gray-700" />

    <!-- Events Table -->
    {{ $events := .Events }}
    <h3 class="mb-4 text-2xl font-bold text-gray-900 dark:text-white">Events</h3>

    {{ if $events }}
    <div class="overflow-x-auto rounded">
      <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
        <thead class="bg-gray-50 dark:bg-gray-700">
          <tr>
            <th class="{{ .Scheme.TableHeader }}">Date</th>
            <th class="{{ .Scheme.TableHeader }}">Name</th>
            <th class="{{ .Scheme.TableHeader }}">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 bg-white dark:divide-gray-700 dark:bg-gray-800">
          {{ range $event := $events }}
            <tr class="{{ $.Scheme.TableRowHover }}">
              <td class="px-6 py-4 whitespace-nowrap text-gray-900 dark:text-gray-100">
                {{ $event.Date }} <span class="text-gray-500 uppercase text-sm">({{ $event.Season }})</span>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-gray-900 dark:text-gray-100">
                {{ $event.Name }}
              </td>
              <td class="px-6 py-4 whitespace-nowrap">
                <a href="{{ $event.URL }}" class="inline-flex items-center rounded bg-{{ $.Scheme.Primary }} px-3 py-1 text-sm text-white hover:bg-{{ $.Scheme.PrimaryHover }} focus:outline-none focus:ring-2 focus:ring-{{ $.Scheme.Primary }} focus:ring-offset-2">
                  <span class="material-symbols-outlined mr-1 text-sm">edit</span>
                  Edit
                </a>
              </td>
            </tr>
          {{ end }}
        </tbody>
      </table>
    </div>
    {{ else }}
    <div class="rounded-lg bg-gray-50 p-8 text-center dark:bg-gray-800">
      <span class="material-symbols-outlined mb-4 text-6xl text-gray-400">calendar_today</span>
      <h3 class="mb-2 text-lg font-semibold text-gray-900 dark:text-white">No Events Found</h3>
      <p class="mb-4 text-gray-600 dark:text-gray-400">
        No tournament events have been created yet. Create your first event to get started.
      </p>
      <a href="/admin/events/new" class="inline-flex items-center rounded-lg bg-{{ .Scheme.Primary }} px-4 py-2 text-sm font-medium text-white hover:bg-{{ .Scheme.PrimaryHover }} focus:outline-none focus:ring-2 focus:ring-{{ .Scheme.Primary }} focus:ring-offset-2">
        <span class="material-symbols-outlined mr-2 text-sm">add</span>
        Create First Event
      </a>
    </div>
    {{ end }}
  </div>
{{ end }}